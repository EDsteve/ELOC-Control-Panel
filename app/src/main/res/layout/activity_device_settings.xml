                        app:helpText="@string/help_bt_during_recording"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:indent="16dp"
                        app:itemType="toggle"
                        app:keyText="@string/enable_during_recording" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:layout_marginStart="16dp" />

                    <de.eloc.eloc_control_panel.widgets.ListItem
                        android:id="@+id/bt_off_timeout_seconds_item"
                        app:helpText="@string/help_bt_off_timeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:indent="16dp"
                        app:itemType="button"
                        app:keyText="Off Timeout"
