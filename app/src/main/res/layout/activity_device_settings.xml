                        app:keyText="@string/region"
                        tools:valueText="4354" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/inference_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="6dp"
                    android:background="@drawable/tile_gradient"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/inference_section_text_view"
                        android:drawablePadding="10dp"
                        app:drawableStartCompat="@drawable/ic_sparkle"
                        app:drawableTint="@color/ui_green"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="?selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:textColor="@color/ui_text_primary"
                        android:textStyle="bold"
                        android:text="@string/inference"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        app:drawableEndCompat="@drawable/keyboard_arrow_down" />

                    <de.eloc.eloc_control_panel.widgets.ListItem
                        android:id="@+id/inference_threshold_item"
                        app:helpText="@string/help_inference_threshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:indent="16dp"
                        app:itemType="button"
                        app:keyText="@string/threshold" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:layout_marginStart="16dp" />

                    <de.eloc.eloc_control_panel.widgets.ListItem
                        android:id="@+id/inference_obs_window_item"
                        app:helpText="@string/help_inference_obs_window"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:indent="16dp"
                        app:itemType="button"
                        app:keyText="@string/observation_window"
                        tools:valueText="4" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:layout_marginStart="16dp" />

                    <de.eloc.eloc_control_panel.widgets.ListItem
                        android:id="@+id/inference_req_detections_item"
                        app:helpText="@string/help_inference_req_detections"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:indent="16dp"
                        app:itemType="button"
                        app:keyText="@string/required_detections"
                        tools:valueText="4354" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/duty_cycle_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="6dp"
                    android:background="@drawable/tile_gradient"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/duty_cycle_section_text_view"
                        android:drawablePadding="10dp"
                        app:drawableStartCompat="@drawable/access_time"
                        app:drawableTint="@color/ui_green"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="?selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:textColor="@color/ui_text_primary"
                        android:textStyle="bold"
                        android:text="@string/duty_cycle"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        app:drawableEndCompat="@drawable/keyboard_arrow_down" />

                    <de.eloc.eloc_control_panel.widgets.ListItem
                        android:id="@+id/duty_cycle_enable_item"
                        app:helpText="@string/help_duty_enable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:indent="16dp"
                        app:itemType="toggle"
                        app:keyText="@string/enabled" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:layout_marginStart="16dp" />

                    <de.eloc.eloc_control_panel.widgets.ListItem
                        android:id="@+id/duty_cycle_sleep_duration_item"
                        app:helpText="@string/help_duty_sleep"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:indent="16dp"
                        app:itemType="button"
                        app:keyText="@string/sleep_duration"
                        tools:valueText="300 secs" />

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="4dp"
                        android:layout_marginStart="16dp" />

                    <de.eloc.eloc_control_panel.widgets.ListItem
                        android:id="@+id/duty_cycle_awake_duration_item"
                        app:helpText="@string/help_duty_awake"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:indent="16dp"
                        app:itemType="button"
                        app:keyText="@string/awake_duration"
                        tools:valueText="30 secs" />
                </LinearLayout>

                <LinearLayout
