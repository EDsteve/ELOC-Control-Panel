<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="HardcodedText"
    android:orientation="vertical">

    <TextView
        android:id="@+id/receive_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#404040"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:freezesText="true"
        android:gravity="bottom"
        android:scrollbars="vertical"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium" />

    <LinearLayout
        android:id="@+id/setupStuff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="0"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"
            android:visibility="gone">

            <TextView

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:layout_weight="1"
                android:letterSpacing="0.1"
                android:text="Other setting:"
                android:textColor="#D5D5D5"
                android:textSize="16sp"
                android:textStyle="bold" />


            <EditText
                android:id="@+id/otherSetting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="8"
                android:inputType="text|textNoSuggestions"
                android:singleLine="true"
                android:text=""
                android:textColor="#AAFFFFFF" />


        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <TextView

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:layout_weight="1"
                android:letterSpacing="0.1"
                android:text="Filename:"
                android:textColor="#D5D5D5"
                android:textSize="16sp"
                android:textStyle="bold" />


            <EditText
                android:id="@+id/locationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="8"
                android:inputType="text|textNoSuggestions"
                android:singleLine="true"
                android:text=""
                android:textColor="#AAFFFFFF" />


        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#232323" />

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:background="#373737" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:lineSpacingExtra="16sp"
            android:paddingLeft="20dp" android:paddingStart="20dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp"
            android:text="Sample Rate"
            android:textAlignment="center"
            android:textColor="#D5D5D5"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupSamplesPerSec"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="35dp"
            android:paddingTop="5dp"
            android:paddingBottom="25dp">

            <RadioButton
                android:id="@+id/rad44k"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="44k"
                android:textColor="#B0FFFFFF" />

            <RadioButton
                android:id="@+id/rad32k"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="32k"
                android:textColor="#B0FFFFFF" />

            <RadioButton
                android:id="@+id/rad22k"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="22k"
                android:textColor="#B0FFFFFF" />

            <RadioButton
                android:id="@+id/rad16k"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="16K"
                android:textColor="#B0FFFFFF" />

            <RadioButton
                android:id="@+id/rad8k"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="8k"
                android:textColor="#B0FFFFFF" />

        </RadioGroup>

        <View
            android:id="@+id/view5"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#232323" />

        <View
            android:id="@+id/view4"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:background="#373737" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:lineSpacingExtra="16sp"
            android:paddingLeft="20dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp"
            android:text="Recording time per file "
            android:textAlignment="viewStart"
            android:textColor="#D5D5D5"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:targetApi="lollipop" />

        <RadioGroup
            android:id="@+id/radioGroupSecPerFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="35dp"
            android:paddingTop="5dp"

            android:paddingBottom="25dp">

            <RadioButton
                android:id="@+id/rad12h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12h"
                android:textColor="#B5FFFFFF" />

            <RadioButton
                android:id="@+id/rad4h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="4h"
                android:textColor="#B5FFFFFF" />

            <RadioButton
                android:id="@+id/rad1h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1h"
                android:textColor="#B5FFFFFF" />

            <RadioButton
                android:id="@+id/rad1m"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1m"
                android:textColor="#B5FFFFFF" />


            <RadioButton
                android:id="@+id/rad10s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10s"
                android:textColor="#B5FFFFFF" />

        </RadioGroup>

        <View
            android:id="@+id/view11"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#252525" />

        <View
            android:id="@+id/view12"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:background="#373737" />


    </LinearLayout>


    <LinearLayout
        android:id="@+id/UnderButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/recBtn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="0.2"
            android:background="#232323"
            android:text="please wait..."
            android:textColor="#FFFFFFFF"
            android:textSize="25sp"
             />

        <Button
            android:id="@+id/gpsBtn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            android:background="#002002"
            android:text="gps"
            android:textColor="#FF000000"
            android:textSize="16sp" />


    </LinearLayout>


</LinearLayout>

