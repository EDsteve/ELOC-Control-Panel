    <!-- Per-setting help texts (settings screen) -->
    <string name="help_node_name">The device\'s name. It is shown in the app, used in status uploads, and identifies this ELOC on the dashboard.\n\n⚠ Changing the node name can break things — DO NOT CHANGE UNLESS YOU KNOW WHAT YOU ARE DOING.</string>
    <string name="help_file_header">Text prefix added to recording file names to identify this deployment or site.</string>
    <string name="help_time_per_file">Length of each recording file. When reached, the current file is closed and a new one is started.</string>
    <string name="help_mic_type">The microphone model fitted to this device. Stored with recordings for documentation — only change it if the hardware was changed.</string>
    <string name="help_mic_gain">Microphone input amplification. Higher gain picks up quieter and more distant sounds, but very loud sounds may clip.</string>
    <string name="help_mic_channel">Which I2S audio channel the microphone is read from (left or right).</string>
    <string name="help_mic_sample_rate">Samples per second of the recording. Higher rates capture higher frequencies but produce larger files and use more power.</string>
    <string name="help_mic_apll">Use the ESP32\'s audio PLL for a more precise sample-rate clock. Needed for some sample rates.</string>
    <string name="help_intruder_enable">Use the built-in accelerometer to detect when someone is moving or removing the device, and record the event.</string>
    <string name="help_intruder_threshold">How much movement (acceleration) is needed to count as an intruder event.</string>
    <string name="help_intruder_window">Time window in milliseconds over which the accelerometer data is evaluated.</string>
    <string name="help_lorawan_enable">Report detections and regular heartbeats over LoRaWAN (The Things Network) — long-range radio, independent of cell coverage.</string>
    <string name="help_lorawan_uplink">How often the device sends a status message over LoRa. Shorter intervals give fresher data but use more power.</string>
    <string name="help_lorawan_region">The LoRaWAN frequency plan for your country or region (e.g. EU868, AS923).</string>
    <string name="help_inference_threshold">Minimum AI confidence for a sound to count as a detection.</string>
    <string name="help_inference_obs_window">Time window over which AI results are collected before deciding whether an event happened.</string>
    <string name="help_inference_req_detections">How many positive AI results are required within the observation window to report an event.</string>
    <string name="help_duty_enable">Save power by alternating between an awake phase (recording/detecting) and a sleep phase.</string>
    <string name="help_duty_sleep">How long the device sleeps in each duty cycle.</string>
    <string name="help_duty_awake">How long the device stays awake in each duty cycle.</string>
    <string name="help_bt_at_start">Make Bluetooth available immediately after the device boots.</string>
    <string name="help_bt_on_tapping">Wake Bluetooth up by tapping/knocking on the device housing.</string>
    <string name="help_bt_during_recording">Keep Bluetooth on while recording. Convenient for checking on the device, but uses more power.</string>
    <string name="help_bt_off_timeout">Seconds of inactivity before Bluetooth switches off to save power.</string>
    <string name="help_cpu_light_sleep">Let the CPU enter light sleep between tasks to save power.</string>
    <string name="help_cpu_min_freq">Lowest CPU clock frequency in MHz. Lower values save power.</string>
    <string name="help_cpu_max_freq">Highest CPU clock frequency in MHz. Higher values speed up AI detection but use more power.</string>
    <string name="help_battery_no_bat">For devices running without a battery (e.g. on mains or lab power) — disables battery monitoring.</string>
    <string name="help_battery_avg_samples">Number of voltage samples averaged for the battery reading.</string>
    <string name="help_battery_avg_interval">Time between the voltage samples used for the battery average.</string>
    <string name="help_battery_update_interval">How often the battery level is measured and updated.</string>
    <string name="help_logs_sd">Write the device\'s diagnostic log to the SD card.</string>
    <string name="help_logs_filename">File name used for the diagnostic log on the SD card.</string>
    <string name="help_logs_max_files">Number of log files kept before the oldest one is overwritten.</string>
    <string name="help_logs_max_size">Maximum size of a log file before a new one is started.</string>
    <string name="help_command_line">Send raw commands directly to the device. For advanced users and troubleshooting.</string>
